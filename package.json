{
  "name": "fitgirl-downloader-wm",
  "productName": "FitGirl Desktop Extractor",
  "version": "1.0.4",
  "description": "FitGirl Downloader by WM - O gerenciador e extrator definitivo para repacks da FitGirl.",
  "author": "WM <lacee.mds@gmail.com>",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsx dev-runner.ts",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-electron/main.js && esbuild electron/preload.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist-electron/preload.js",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && npm run build:electron",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist dist-electron dist-desktop",
    "lint": "tsc --noEmit",
    "package": "electron-builder --win",
    "publish": "electron-builder --win --publish always",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.fitgirl.extractor",
    "productName": "FitGirl Desktop Extractor",
    "copyright": "Copyright © 2026 WM",
    "directories": {
      "output": "dist-desktop",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "FitGirl Desktop Extractor",
      "runAfterFinish": true,
      "perMachine": true,
      "uninstallDisplayName": "FitGirl Desktop Extractor (Remover)",
      "artifactName": "FitGirl-Desktop-Extractor-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "FitGirl-Desktop-Extractor-Portable-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ualasimendes",
        "repo": "FITGIRL-DOWNLOADER-BY-WM"
      }
    ]
  }
}
